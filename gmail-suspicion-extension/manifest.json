{
  "manifest_version": 3,
  "name": "Gmail Suspicion Meter",
  "version": "1.0.0",
  "description": "Gmailの一覧にメールの怪しさを%表示し、AIの判定結果を少量の特徴量として記憶します。",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["https://mail.google.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Gmail Suspicion Meter を開く"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
