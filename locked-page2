<meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'unsafe-inline' blob:; style-src 'unsafe-inline'; img-src 'self' data: blob:; font-src 'none'; connect-src 'self' https:; object-src 'none'; base-uri 'none'; form-action 'none'; frame-src 'self' data: blob:;">
<title>Private Page</title>
<script>
(function () {
  try {
    if (true) {
      const key = new URLSearchParams(window.location.search).get('key');
      if (key) document.documentElement.classList.add('auto-unlocking');
    }
  } catch (_) {}
})();
</script>
<style>
  * { box-sizing: border-box; }
  body {
    margin: 0;
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 20px;
    color: #172033;
    background:
      radial-gradient(circle at 20% 0%, rgba(37,99,235,.20), transparent 26rem),
      linear-gradient(135deg, #f8fbff, #eef5ff);
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Yu Gothic", sans-serif;
  }
  .box {
    width: min(430px, 100%);
    border: 1px solid #d9e4f2;
    background: #fff;
    border-radius: 28px;
    box-shadow: 0 24px 70px rgba(15,62,168,.16);
    overflow: hidden;
  }
  .top {
    padding: 28px 24px;
    color: #fff;
    background: linear-gradient(135deg, #102a60, #2563eb);
    text-align: center;
  }
  .top h1 {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.45;
  }
  .main { padding: 24px; }
  input {
    width: 100%;
    padding: 13px 14px;
    border: 1px solid #c7d7eb;
    border-radius: 16px;
    outline: none;
    font: inherit;
    margin-bottom: 12px;
    background: #fbfdff;
  }
  input:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 4px rgba(37,99,235,.13);
  }
  button {
    width: 100%;
    border: 0;
    border-radius: 18px;
    padding: 14px 18px;
    background: linear-gradient(135deg, #2563eb, #0f3ea8);
    color: white;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }
  button:disabled {
    opacity: .62;
    cursor: default;
  }
  button.secondary {
    margin-top: 10px;
    color: #172033;
    background: #eef5ff;
    border: 1px solid #c7d7eb;
  }
  input[type=file] { display: none; }
  .message {
    min-height: 1.4em;
    margin-top: 14px;
    color: #667085;
    text-align: center;
    font-size: .9rem;
