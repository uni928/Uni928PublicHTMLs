<body>
<div class="box">
  <div class="top"><h1>🔒 Private Page</h1></div>
  <div class="main">
    <input id="unlockKey" type="password" placeholder="パスワードを入力" autocomplete="current-password" autofocus>
    <button id="unlockButton" type="button">開く</button>
    <button id="openUnlockFileButton" class="secondary" type="button">解除用ファイルを開く</button>
    <input id="unlockFileInput" type="file" accept=".txt,text/plain">
    <div id="message" class="message"></div>
  </div>
</div>
<script>
const PAGE_TITLE = "Private Page";
const QUERY_UNLOCK = true;
const REMEMBER_UNLOCK = false;
const STRICT_VIEW = false;
const CAPACITY_SAVE = true;
const TWO_STAGE_JAVASCRIPT = true;
const STAGE2_KEY = "KaPzUR1NsBJkL67NqM4TsA5OSRBfPWlXIBRC5pPyMJZcflHeZwHM4uOJxVK5B8B75XOhd0XCi1KDjEm4ZUJtF3eMAL958Jqggf7Y";
const STAGE2_SALT = "CkSC16EBbkikcPncQzh3cw==";
const STAGE2_IV = "OvCwAIXZGdODUxNl";
const STAGE2_DATA = "";
const LOCKED_SALT = "8BYVEZ+ydqYuJr+sxrzfQA==";
const LOCKED_IV = "3KbOjH5tvfgnJxvY";
const LOCKED_DATA = "";
const UNLOCK_STORAGE_SECRET = "UtbZXuVHlmoFeOTTMQYW8BadRnw3130TWOaB8GWN3RSF1LtGSmKgAu4KXpDLzrHWpIuH2nRY8D8o9bZo3i06IaNcEOHKLFzDbS93";

function fromBase64(value) {
  return Uint8Array.from(atob(value), char => char.charCodeAt(0));
}

function toBase64(buffer) {
  const bytes = buffer instanceof Uint8Array ? buffer : new Uint8Array(buffer);
  let binary = '';
  const chunkSize = 32768;
  for (let i = 0; i < bytes.length; i += chunkSize) {
    binary += String.fromCharCode.apply(null, bytes.subarray(i, i + chunkSize));
  }
  return btoa(binary);
}

function hideQueryKey() {
  try {
    const url = new URL(window.location.href);
    if (!url.searchParams.has('key')) return;
    url.searchParams.delete('key');
    window.history.replaceState(null, '', url.pathname + url.search + url.hash);
  } catch (_) {}
}

function showUnlockScreen() {
  document.documentElement.classList.remove('auto-unlocking');
}

function riskyUrl(value) {
  const text = String(value || '').trim();
  if (!text) return false;
  if (/^(javascript|vbscript|data:text\/html)/i.test(text)) return true;
  try {
    const url = new URL(text, window.location.href);
    return ['http:', 'https:', 'ftp:', 'ws:', 'wss:'].includes(url.protocol);
  } catch (_) {
    return false;
  }
}

function cleanCss(text) {
  return String(text || '')
    .replace(/@import[^;]+;/gi, '')
    .replace(/url\s*\(([^)]*)\)/gi, (all, raw) => {
      const value = raw.trim().replace(/^['"]|['"]$/g, '');
      return riskyUrl(value) ? 'none' : all;
    });
}

function staticOnly(html) {
  const doc = new DOMParser().parseFromString(html, 'text/html');
  doc.querySelectorAll('script, iframe, frame, object, embed, meta[http-equiv="refresh"], link[rel="preload"], link[rel="prefetch"], link[rel="preconnect"], link[rel="dns-prefetch"], link[rel="modulepreload"]').forEach(node => node.remove());

  doc.querySelectorAll('link').forEach(node => {
    const rel = (node.getAttribute('rel') || '').toLowerCase();
    const href = node.getAttribute('href') || '';
    if (rel.includes('stylesheet') || riskyUrl(href)) node.remove();
  });

  doc.querySelectorAll('style').forEach(node => {
    node.textContent = cleanCss(node.textContent);
  });

  const urlAttributes = new Set(['src', 'srcset', 'href', 'poster', 'action', 'formaction', 'data', 'background']);
  doc.querySelectorAll('*').forEach(node => {
    for (const attr of Array.from(node.attributes)) {
      const name = attr.name.toLowerCase();
      if (name.startsWith('on')) node.removeAttribute(attr.name);
      else if (name === 'style') node.setAttribute('style', cleanCss(attr.value));
      else if (urlAttributes.has(name) && riskyUrl(attr.value)) node.removeAttribute(attr.name);
    }
  });

  const meta = doc.createElement('meta');
  meta.setAttribute('name', 'referrer');
  meta.setAttribute('content', 'no-referrer');
  doc.head.prepend(meta);

  return '<!DOCTYPE html>' + doc.documentElement.outerHTML;
}

async function gunzip(bytes) {
  if (!window.DecompressionStream) throw new Error('このブラウザは解凍APIに対応していません。');
  const stream = new Blob([bytes]).stream().pipeThrough(new DecompressionStream('gzip'));
  return await new Response(stream).arrayBuffer();
}

async function A7qM2zLp() {
  if (!TWO_STAGE_JAVASCRIPT || !STAGE2_KEY || !STAGE2_SALT || !STAGE2_IV || !STAGE2_DATA) return [];
  const secret = await crypto.subtle.importKey('raw', new TextEncoder().encode(STAGE2_KEY), 'PBKDF2', false, ['deriveKey']);
  const key = await crypto.subtle.deriveKey(
    { name: 'PBKDF2', salt: fromBase64(STAGE2_SALT), iterations: 600000, hash: 'SHA-256' },
    secret,
    { name: 'AES-GCM', length: 256 },
    false,
    ['decrypt']
  );
  const plain = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: fromBase64(STAGE2_IV) }, key, fromBase64(STAGE2_DATA));
  const body = CAPACITY_SAVE ? await gunzip(new Uint8Array(plain)) : plain;
  const parsed = JSON.parse(new TextDecoder().decode(body));
  return Array.isArray(parsed) ? parsed : [];
}

function setScriptAttributes(target, attrs) {
  for (const [name, value] of Object.entries(attrs || {})) {
    if (name.toLowerCase() === 'src') continue;
    try { target.setAttribute(name, value); } catch (_) {}
  }
}

function Ab5Kx9Rt(record) {
  return new Promise(resolve => {
    const attrs = record.attrs || {};
    const script = document.createElement('script');
    let blobUrl = '';
    let done = false;
    const finish = () => {
      if (done) return;
      done = true;
      if (blobUrl) URL.revokeObjectURL(blobUrl);
      try { script.remove(); } catch (_) {}
      resolve();
    };
    setScriptAttributes(script, attrs);
    script.onload = finish;
    script.onerror = finish;

    if (attrs.src) {
      script.src = attrs.src;
    } else {
      blobUrl = URL.createObjectURL(new Blob([record.text || ''], { type: 'text/javascript' }));
      script.src = blobUrl;
    }

    (document.body || document.documentElement).appendChild(script);
  });
}

async function runStage2Scripts() {
  try {
    const scripts = await A7qM2zLp();
    for (const record of scripts) await Ab5Kx9Rt(record);
  } catch (error) {
    console.error('Stage2 JavaScript restore failed:', error);
  }
}

function stage2LoaderScript() {
  if (!TWO_STAGE_JAVASCRIPT || STRICT_VIEW) return '';
  const loader = '(' + function(config) {
    function fromBase64(value) {
      return Uint8Array.from(atob(value), function(char) { return char.charCodeAt(0); });
    }
    async function gunzip(bytes) {
      if (!window.DecompressionStream) throw new Error('このブラウザは解凍APIに対応していません。');
      const stream = new Blob([bytes]).stream().pipeThrough(new DecompressionStream('gzip'));
      return await new Response(stream).arrayBuffer();
    }
    async function A7qM2zLp() {
      const secret = await crypto.subtle.importKey('raw', new TextEncoder().encode(config.key), 'PBKDF2', false, ['deriveKey']);
      const key = await crypto.subtle.deriveKey(
        { name: 'PBKDF2', salt: fromBase64(config.salt), iterations: 600000, hash: 'SHA-256' },
        secret,
        { name: 'AES-GCM', length: 256 },
        false,
        ['decrypt']
      );
      const plain = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: fromBase64(config.iv) }, key, fromBase64(config.data));
      const body = config.capacitySave ? await gunzip(new Uint8Array(plain)) : plain;
      const parsed = JSON.parse(new TextDecoder().decode(body));
      return Array.isArray(parsed) ? parsed : [];
    }
    function setScriptAttributes(target, attrs) {
      Object.entries(attrs || {}).forEach(function(entry) {
        const name = entry[0];
        const value = entry[1];
        if (String(name).toLowerCase() === 'src') return;
        try { target.setAttribute(name, value); } catch (_) {}
      });
    }
    function Ab5Kx9Rt(record) {
      return new Promise(function(resolve) {
        const script = document.createElement('script');
        const attrs = record.attrs || {};
        let blobUrl = '';
        let done = false;
        function finish() {
          if (done) return;
          done = true;
          if (blobUrl) URL.revokeObjectURL(blobUrl);
          try { script.remove(); } catch (_) {}
          resolve();
        }
        setScriptAttributes(script, attrs);
        script.onload = finish;
        script.onerror = finish;
        if (attrs.src) {
          script.src = attrs.src;
        } else {
          blobUrl = URL.createObjectURL(new Blob([record.text || ''], { type: 'text/javascript' }));
          script.src = blobUrl;
        }
        (document.body || document.documentElement).appendChild(script);
      });
    }
    async function main() {
      try {
        const scripts = await A7qM2zLp();
        for (const record of scripts) await Ab5Kx9Rt(record);
      } catch (error) {
        console.error('Stage2 JavaScript restore failed:', error);
      }
    }
    main();
  } + ')(' + JSON.stringify({
    key: STAGE2_KEY,
    salt: STAGE2_SALT,
    iv: STAGE2_IV,
    data: STAGE2_DATA,
    capacitySave: CAPACITY_SAVE
  }) + ');';
  const closingScriptPattern = new RegExp('<' + '/script', 'gi');
  const safeLoader = loader.replace(closingScriptPattern, '<' + '\/script');
  return '<script>' + safeLoader + '<\/script>';
}

function injectStage2Loader(html) {
  if (!TWO_STAGE_JAVASCRIPT || STRICT_VIEW) return html;
  const loader = stage2LoaderScript();
  const closingBodyPattern = new RegExp('<' + '/body>', 'i');
  if (closingBodyPattern.test(html)) return html.replace(closingBodyPattern, loader + '<' + '/body>');
  return html + loader;
}

async function openHtml(html) {
  const scripts = (!STRICT_VIEW && TWO_STAGE_JAVASCRIPT) ? await A7qM2zLp() : [];
  const output = STRICT_VIEW ? staticOnly(html) : html;
  document.open();
  document.write(output);
  document.close();
  if (scripts.length) {
    for (const record of scripts) await Ab5Kx9Rt(record);
  }
}

const UNLOCK_DB_NAME = 'local-html-locker-unlock-passwords';
const UNLOCK_DB_VERSION = 1;
const UNLOCK_STORE_NAME = 'kv';
const UNLOCK_PASSWORDS_KEY = 'passwords:' + UNLOCK_STORAGE_SECRET;
const UNLOCK_PASSWORDS_BLOB_VERSION = 3;

function canUseUnlockStorage() {
  return REMEMBER_UNLOCK && /^[A-Za-z0-9]{100}$/.test(UNLOCK_STORAGE_SECRET);
}

function openUnlockDb() {
  return new Promise((resolve, reject) => {
    if (!window.indexedDB) {
      reject(new Error('このブラウザはIndexedDBに対応していません。'));
      return;
    }
    const request = indexedDB.open(UNLOCK_DB_NAME, UNLOCK_DB_VERSION);
    request.onupgradeneeded = event => {
      const db = event.target.result;
      if (!db.objectStoreNames.contains(UNLOCK_STORE_NAME)) db.createObjectStore(UNLOCK_STORE_NAME);
    };
    request.onsuccess = () => resolve(request.result);
    request.onerror = () => reject(request.error || new Error('IndexedDBを開けませんでした。'));
  });
}

async function unlockDbGet(key, fallbackValue) {
  const db = await openUnlockDb();
  return new Promise((resolve, reject) => {
    const tx = db.transaction(UNLOCK_STORE_NAME, 'readonly');
    const store = tx.objectStore(UNLOCK_STORE_NAME);
    const request = store.get(key);
    request.onsuccess = () => resolve(request.result ?? fallbackValue);
    request.onerror = () => reject(request.error || new Error('IndexedDBの読込に失敗しました。'));
    tx.oncomplete = () => db.close();
    tx.onerror = () => { db.close(); reject(tx.error || new Error('IndexedDBの読込に失敗しました。')); };
  });
}

async function unlockDbSet(key, value) {
  const db = await openUnlockDb();
  return new Promise((resolve, reject) => {
    const tx = db.transaction(UNLOCK_STORE_NAME, 'readwrite');
    const store = tx.objectStore(UNLOCK_STORE_NAME);
    store.put(value, key);
    tx.oncomplete = () => { db.close(); resolve(); };
    tx.onerror = () => { db.close(); reject(tx.error || new Error('IndexedDBの保存に失敗しました。')); };
  });
}

async function deriveUnlockStorageKey(salt) {
  const seed = await crypto.subtle.importKey('raw', new TextEncoder().encode(UNLOCK_STORAGE_SECRET), 'PBKDF2', false, ['deriveKey']);
  return crypto.subtle.deriveKey(
    { name: 'PBKDF2', salt, iterations: 210000, hash: 'SHA-256' },
    seed,
    { name: 'AES-GCM', length: 256 },
    false,
    ['encrypt', 'decrypt']
  );
}

async function encryptSavedPasswords(passwords) {
  const salt = crypto.getRandomValues(new Uint8Array(16));
  const iv = crypto.getRandomValues(new Uint8Array(12));
  const key = await deriveUnlockStorageKey(salt);
  const cleanPasswords = Array.from(new Set(passwords.filter(item => typeof item === 'string' && item)));
  const plain = new TextEncoder().encode(JSON.stringify(cleanPasswords));
  const data = await crypto.subtle.encrypt({ name: 'AES-GCM', iv }, key, plain);
  return {
    v: UNLOCK_PASSWORDS_BLOB_VERSION,
    alg: 'AES-GCM/PBKDF2-SHA256',
    marker: UNLOCK_STORAGE_SECRET,
    salt: toBase64(salt),
    iv: toBase64(iv),
    data: toBase64(data)
  };
}

async function decryptSavedPasswordsBlob(blob) {
  if (!canUseUnlockStorage()) return [];
  if (!blob || blob.v !== UNLOCK_PASSWORDS_BLOB_VERSION || blob.marker !== UNLOCK_STORAGE_SECRET || !blob.salt || !blob.iv || !blob.data) return [];
  const key = await deriveUnlockStorageKey(fromBase64(blob.salt));
  const plain = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: fromBase64(blob.iv) }, key, fromBase64(blob.data));
  const parsed = JSON.parse(new TextDecoder().decode(plain));
  return Array.isArray(parsed) ? parsed.filter(item => typeof item === 'string' && item) : [];
}

async function getSavedPasswords() {
  if (!canUseUnlockStorage()) return [];
  try {
    const value = await unlockDbGet(UNLOCK_PASSWORDS_KEY, null);
    return await decryptSavedPasswordsBlob(value);
  } catch (_) {
    return [];
  }
}

async function savePasswordIfNeeded(passphrase) {
  if (!canUseUnlockStorage() || !passphrase) return;
  try {
    const passwords = await getSavedPasswords();
    if (passwords.includes(passphrase)) return;
    passwords.push(passphrase);
    await unlockDbSet(UNLOCK_PASSWORDS_KEY, await encryptSavedPasswords(passwords));
  } catch (_) {}
}

async function decryptWithPassphrase(passphrase) {
  const secret = await crypto.subtle.importKey('raw', new TextEncoder().encode(passphrase), 'PBKDF2', false, ['deriveKey']);
  const key = await crypto.subtle.deriveKey(
    { name: 'PBKDF2', salt: fromBase64(LOCKED_SALT), iterations: 600000, hash: 'SHA-256' },
    secret,
    { name: 'AES-GCM', length: 256 },
    false,
    ['decrypt']
  );
  const plain = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: fromBase64(LOCKED_IV) }, key, fromBase64(LOCKED_DATA));
  const body = CAPACITY_SAVE ? await gunzip(new Uint8Array(plain)) : plain;
  return new TextDecoder().decode(body);
}

async function tryUnlockWithPassphrase(passphrase, option) {
  const showProgress = option && option.showProgress;
  const showFailure = option && option.showFailure;
  const saveOnSuccess = !option || option.saveOnSuccess !== false;
  const button = document.getElementById('unlockButton');
  const message = document.getElementById('message');

  if (showProgress) {
    message.className = 'message';
    message.textContent = '復号しています...';
    button.disabled = true;
  }

  try {
    const html = await decryptWithPassphrase(passphrase);
    if (saveOnSuccess) await savePasswordIfNeeded(passphrase);
    await openHtml(html);
    return true;
  } catch (_) {
    showUnlockScreen();
    if (showFailure) {
      message.className = 'message error';
      message.textContent = 'パスワードが一致しません';
    }
    return false;
  } finally {
    if (showProgress) button.disabled = false;
  }
}

async function unlock() {
  const input = document.getElementById('unlockKey');
  await tryUnlockWithPassphrase(input.value, { showProgress: true, showFailure: true, saveOnSuccess: true });
}

function extractPasswordFromInfoText(text) {
  const lines = String(text || '').split(/\r?\n/);
  for (let i = 0; i < lines.length; i++) {
    if (lines[i].trim() === '【パスワード】') {
      for (let j = i + 1; j < lines.length; j++) {
        const value = lines[j].trim();
        if (value) return value;
      }
      return '';
    }
  }
  return '';
}

async function openUnlockFile(file) {
  const message = document.getElementById('message');
  try {
    const text = await file.text();
    const password = extractPasswordFromInfoText(text);
    if (!password) {
      message.className = 'message error';
      message.textContent = '解除用ファイルからパスワードを読み取れませんでした';
      return;
    }
    document.getElementById('unlockKey').value = password;
    await tryUnlockWithPassphrase(password, { showProgress: true, showFailure: true, saveOnSuccess: true });
  } catch (_) {
    message.className = 'message error';
    message.textContent = '解除用ファイルを開けませんでした';
  }
}

async function trySavedPasswordsSilently() {
  const passwords = await getSavedPasswords();
  for (const password of passwords) {
    const ok = await tryUnlockWithPassphrase(password, { showProgress: false, showFailure: false, saveOnSuccess: false });
    if (ok) return true;
  }
  return false;
}

async function boot() {
  let queryTried = false;
  if (QUERY_UNLOCK) {
    const key = new URLSearchParams(window.location.search).get('key');
    if (key) {
      queryTried = true;
      document.getElementById('unlockKey').value = key;
      hideQueryKey();
      const ok = await tryUnlockWithPassphrase(key, { showProgress: true, showFailure: true, saveOnSuccess: true });
      if (ok) return;
    }
  }

  const savedOk = await trySavedPasswordsSilently();
  if (!savedOk && !queryTried) showUnlockScreen();
}

document.getElementById('unlockButton').addEventListener('click', unlock);
document.getElementById('unlockKey').addEventListener('keydown', event => {
  if (event.key === 'Enter') unlock();
});
document.getElementById('openUnlockFileButton').addEventListener('click', () => {
  document.getElementById('unlockFileInput').click();
});
document.getElementById('unlockFileInput').addEventListener('change', event => {
  const file = event.target.files && event.target.files[0];
  if (file) openUnlockFile(file);
  event.target.value = '';
});
boot();
</script>
</body>
